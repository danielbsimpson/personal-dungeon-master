# ─── LLM Provider ────────────────────────────────────────────────────────────
# Which LLM backend to use: "openai" or "ollama"
LLM_PROVIDER=openai

# ─── OpenAI ──────────────────────────────────────────────────────────────────
# Required when LLM_PROVIDER=openai
OPENAI_API_KEY=sk-...

# ─── Ollama ──────────────────────────────────────────────────────────────────
# Required when LLM_PROVIDER=ollama
# Default: http://localhost:11434
OLLAMA_BASE_URL=http://localhost:11434

# ─── Model ───────────────────────────────────────────────────────────────────
# The model to use for the DM agent.
# OpenAI examples: gpt-4o, gpt-4o-mini, o4-mini
# Ollama examples: llama3, mistral, gemma3, deepseek-r2
# Leave blank when LLM_PROVIDER=ollama to get an interactive model picker at startup.
DM_MODEL=gpt-4o

# ─── Rules ───────────────────────────────────────────────────────────────────
# Which game edition rules to load from the rules/ directory.
# Default: 5e
GAME_EDITION=5e

# ─── Directories ─────────────────────────────────────────────────────────────
# Paths are relative to the project root unless absolute.
# Leave blank to use the defaults shown below.
CAMPAIGNS_DIR=campaigns
MEMORY_DIR=memory
RULES_DIR=rules
