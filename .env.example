# ─── LLM Provider ────────────────────────────────────────────────────────────
# Which LLM backend to use: "openai" or "llamacpp"
LLM_PROVIDER=llamacpp

# ─── OpenAI ──────────────────────────────────────────────────────────────────
# Required when LLM_PROVIDER=openai
OPENAI_API_KEY=sk-...

# ─── llama.cpp ───────────────────────────────────────────────────────────────
# Required when LLM_PROVIDER=llamacpp
# Default: http://localhost:8080
# Start the server: llama-server -m path/to/model.gguf -c 4096
LLAMACPP_BASE_URL=http://localhost:8080

# ─── Model ───────────────────────────────────────────────────────────────────
# The model to use for the DM agent.
# OpenAI examples: gpt-4o, gpt-4o-mini, o4-mini
# llama.cpp: use the model ID shown by the server (typically the .gguf path or alias)
# Leave blank when LLM_PROVIDER=llamacpp to auto-detect from the running server.
DM_MODEL=llama3.1:8b

# ─── Rules ───────────────────────────────────────────────────────────────────
# Which game edition rules to load from the rules/ directory.
# Default: 5e
GAME_EDITION=5e

# ─── Directories ─────────────────────────────────────────────────────────────
# Paths are relative to the project root unless absolute.
# Leave blank to use the defaults shown below.
CAMPAIGNS_DIR=campaigns
MEMORY_DIR=memory
RULES_DIR=rules

# ─── Memory / Graphiti ───────────────────────────────────────────────────────
# Number of most-recent messages to keep in the short-term session window.
SESSION_WINDOW=20

# Embedding model for Graphiti entity embeddings
# Run a dedicated llama.cpp embedding server: llama-server -m nomic-embed-text.gguf --embedding
EMBEDDING_MODEL=nomic-embed-text

# Embedding vector dimension — must match the model above.
# nomic-embed-text = 768  |  mxbai-embed-large = 1024  |  text-embedding-3-small = 1536
EMBEDDING_DIM=768

# Set to false to opt out of Graphiti/Zep anonymous usage telemetry.
GRAPHITI_TELEMETRY_ENABLED=false
